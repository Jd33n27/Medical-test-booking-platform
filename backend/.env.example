# Server Configuration
PORT=5000

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-HOST]:5432/postgres?sslmode=require

# Payment Integration (Flutterwave)
FLUTTERWAVE_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_HASH=my_secret_webhook_hash
BYPASS_PAYMENT=true
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Email Integration (Brevo)
BREVO_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx
SENDER_EMAIL=noreply@example.com
SENDER_NAME="MedBook"
